{pkgs,lib,...}:
{
 systemd.user.services."set-wallpaper" = {
    Unit = {
      Description = "Set wallpaper via awww";
    };

    Install = {
      WantedBy = [ "graphical-session.target" ];
    };

    Service = {
      Type = "oneshot";
      ExecStart = ''
        ${pkgs.lib.getExe pkgs.awww} img ~/Pictures/wp.jpg --transition-type none
      '';

      After = [ "awww.service" ];
      Restart = "on-failure";
    };
  };
